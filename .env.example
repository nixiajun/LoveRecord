# ========== 复制为 backend/.env 或项目根 .env ==========

# --- 数据库 ---
DATABASE_URL=postgresql+psycopg2://loverecord:loverecord@localhost:5432/loverecord

# --- 种子用户（python -m app.seed）---
# SEED_ADMIN_PASSWORD=your-strong-password
# SEED_PARTNER_PASSWORD=your-strong-password

# --- JWT ---
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- 上传文件存储（本地 MVP）---
UPLOAD_DIR=./data/uploads

# --- 向量维度（需与 embedding 模型一致）---
EMBEDDING_DIMENSION=1536

# --- AI Provider（OpenAI 兼容 HTTP；实现可替换）---
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

EMBEDDING_API_BASE=https://api.openai.com/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# --- OpenClaw Webhook（Bot 校验用；也可在 DB 扩展）---
OPENCLAW_BEARER_TOKEN=dev-openclaw-token
OPENCLAW_DEFAULT_COUPLE_ID=1

# --- OpenClaw 工具链 → 本后端（与前端用户 JWT 无关）---
LOVE_BACKEND_INTERNAL_TOKEN=dev-love-internal-token
# 可选：bot_id 映射 JSON 数组（迁移 009 后建议用 bot_identities 表）；示例见 deploy/openclaw/env.example
# OPENCLAW_BOT_IDENTITIES_JSON=
OPENCLAW_DEBUG_ENDPOINTS_ENABLED=false

# LoveRecord → OpenClaw / wx 推送（双通道）
# OPENCLAW_PUSH_WEBHOOK_URL=
# OPENCLAW_ME_PUSH_WEBHOOK_URL=
# OPENCLAW_PARTNER_PUSH_WEBHOOK_URL=
# OPENCLAW_PUSH_BEARER_TOKEN=
# OPENCLAW_ENABLE_SCHEDULER_PUSH=false

# --- CORS（前端开发）---
CORS_ORIGINS=http://localhost:3000

# ========== 前端 frontend/.env.local ==========
# NEXT_PUBLIC_API_URL=http://localhost:8000

# ========== Docker Compose（可选）==========
# NEXT_PUBLIC_API_URL=http://localhost:8000
# CORS_ORIGINS=http://localhost:3000
# POSTGRES_PORT=5432
# BACKEND_PORT=8000
# WEB_PORT=3000
