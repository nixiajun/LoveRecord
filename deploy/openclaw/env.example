# LoveRecord 主后端
LOVE_BACKEND_URL=http://127.0.0.1:8000
LOVE_BACKEND_INTERNAL_TOKEN=change-me-long-random

# 兼容旧文档命名
OPENCLAW_INTERNAL_API_TOKEN=${LOVE_BACKEND_INTERNAL_TOKEN}

# Bot 映射（MVP：可先仅用 JSON，生产建议 alembic 009 写 bot_identities 表）
BOT_ME_ID=bot_me
BOT_PARTNER_ID=bot_partner
# 粘贴为单行 JSON 数组（couple_id / acting_user_id 按你库内实际 ID 填写），或留空仅用 DB 表 bot_identities
# OPENCLAW_BOT_IDENTITIES_JSON=

# 双网关各自的 hook 验签 / 路由密钥（OpenClaw 侧占位）
OPENCLAW_ME_HOOK_TOKEN=
OPENCLAW_PARTNER_HOOK_TOKEN=

# LoveRecord → OpenClaw 推送（两个微信各一条 URL；可同机不同端口）
OPENCLAW_ME_PUSH_WEBHOOK_URL=
OPENCLAW_PARTNER_PUSH_WEBHOOK_URL=
OPENCLAW_PUSH_BEARER_TOKEN=

# 定时任务：简报刷新后是否尝试推送（需配置 push URL）
OPENCLAW_ENABLE_SCHEDULER_PUSH=false

# 调试接口（生产务必 false）
OPENCLAW_DEBUG_ENDPOINTS_ENABLED=false
